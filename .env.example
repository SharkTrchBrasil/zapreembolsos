# Configurações Globais do ZapReembolso
PROJECT_NAME="ZapReembolso API"
DEBUG=False

# Banco de Dados PostgreSQL (Coolify / Produção)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="sua_senha_segura"
POSTGRES_DB="zapreembolso"
# Exemplo PostgreSQL no Coolify:
DATABASE_URL="postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres_host:5432/${POSTGRES_DB}"

# Para testes locais com SQLite:
# DATABASE_URL="sqlite+aiosqlite:///./zapreembolso.db"

# Integração com WuzAPI (Container do WuzAPI no Coolify)
WUZAPI_BASE_URL="http://wuzapi:8080"
WUZAPI_USER_TOKEN="seu_token_wuzapi_aqui"

# Token de Segurança do Webhook (para proteger o endpoint)
WEBHOOK_SECRET="seu_token_super_secreto"

# OpenAI API Key (OCR de Cupons Fiscais por IA)
OPENAI_API_KEY="sk-proj-sua_chave_openai_aqui"
